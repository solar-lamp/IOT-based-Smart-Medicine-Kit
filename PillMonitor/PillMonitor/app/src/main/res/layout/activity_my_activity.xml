<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- PAGE TITLE -->
        <TextView
            android:id="@+id/titleMyActivity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="22dp"
            android:text="My Activity"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <!-- PROFILE CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/inputName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/green_primary"
                    android:hint="Your Name"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="14dp"
                    android:text="Save Profile"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/card_dark_2"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/green_primary"
                    app:strokeWidth="1dp"/>

                <!-- SAVED PROFILE -->
                <LinearLayout
                    android:id="@+id/profileDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtProfileName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:id="@+id/btnEditProfile"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Edit profile"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="@color/green_primary"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- APPOINTMENT TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Doctor Appointment"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <!-- APPOINTMENT CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- APPOINTMENT LIST -->
                <LinearLayout
                    android:id="@+id/appointmentList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:orientation="vertical"/>

                <!-- NOTES -->
                <EditText
                    android:id="@+id/inputDoctor"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:backgroundTint="@color/purple_accent"
                    android:gravity="top"
                    android:hint="Doctor note"
                    android:padding="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"/>

                <!-- DATE BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:text="Pick Appointment Date"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/card_dark_2"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/purple_accent"
                    app:strokeWidth="1dp"/>

                <!-- DATE TEXT -->
                <TextView
                    android:id="@+id/txtDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="No date selected"
                    android:textColor="@color/green_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <!-- TIME BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickTime"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:text="Pick Appointment Time"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/card_dark_2"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/purple_accent"
                    app:strokeWidth="1dp"/>

                <!-- TIME TEXT -->
                <TextView
                    android:id="@+id/txtTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="No time selected"
                    android:textColor="@color/green_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <!-- SAVE BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveDoctor"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="22dp"
                    android:text="Save Appointment &amp; Notify"
                    android:textAllCaps="false"
                    android:textColor="@color/bg_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/green_primary"
                    app:cornerRadius="18dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>